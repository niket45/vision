# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
.env

# Type checking
.mypy_cache/
.dmypy.json

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ML & weights — do NOT commit large binaries
weights/
*.pt
*.pth
*.onnx
*.safetensors

# Datasets — raw images are NOT tracked by git (use DVC or separate storage)
datasets/raw/
datasets/annotated/
datasets/splits/

# Experiment outputs
experiments/*/outputs/
experiments/*/checkpoints/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
# Allow notebooks (tracked for collaboration)
!notebooks/*.ipynb

# Logs
*.log
logs/

# Temp
tmp/
.tmp/
